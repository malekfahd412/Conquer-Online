# =============================================================================
#  Conquer Online — Discord AI Operating System
#  Environment Variables Template
#
#  Copy this file to .env and fill in your values, OR set the variables
#  directly in your hosting panel (Pterodactyl / Legacy Bot Hosting).
#
#  Lines starting with # are comments and are ignored.
# =============================================================================

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# Discord bot token from https://discord.com/developers/applications → Bot → Token
DISCORD_BOT_TOKEN=

# The ID of the Discord channel where the live server status embed is posted
# Right-click a channel in Discord → Copy Channel ID (Developer Mode must be on)
CHANNEL_SERVER_STATUS=

# Your game/community server name (shown in the status embed header)
# If the name contains spaces, wrap it in quotes: SERVER_NAME="My Server"
SERVER_NAME=Mufasa Conquer

# ── AI PROVIDER (at least one required for AI features) ───────────────────────

# Which AI provider to use: gemini | openai | openrouter | groq  (default: gemini)
AI_PROVIDER=gemini

# Google Gemini API key — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# OpenAI API key — https://platform.openai.com/api-keys
# Required for AI_PROVIDER=openai and for Voice STT/TTS features
# OPENAI_API_KEY=

# OpenRouter API key — https://openrouter.ai/keys
# OPENROUTER_API_KEY=

# Groq API key — https://console.groq.com/keys
# GROQ_API_KEY=

# ── DATA SOURCE (optional — defaults to "mock" which shows placeholder data) ──

# Where to pull live game server data from: mssql | api | mock  (default: mock)
# DATA_SOURCE=mock

# MSSQL credentials (only used when DATA_SOURCE=mssql)
# MSSQL_SERVER=
# MSSQL_PORT=1433
# MSSQL_DATABASE=
# MSSQL_USER=
# MSSQL_PASSWORD=

# REST API URL (only used when DATA_SOURCE=api)
# GAME_SERVER_API_URL=

# ── SERVER BRANDING (optional) ────────────────────────────────────────────────

# URL to your server logo image (shown in the status embed)
# SERVER_LOGO_URL=

# Social / website links shown as buttons on the status embed
# SERVER_WEBSITE=
# FACEBOOK_URL=
# WHATSAPP_URL=
# DISCORD_INVITE=
# INSTAGRAM_URL=
# YOUTUBE_URL=
# TIKTOK_URL=

# ── AI CONTROL CENTER (optional) ─────────────────────────────────────────────

# Role ID of the admin/moderator role that can use AI commands
# ROLE_ADMIN=

# Channel where the AI posts execution logs (leave blank to disable)
# CHANNEL_AI_LOG=

# Channel where members can chat with the AI (leave blank = slash command only)
# CHANNEL_AI_CHAT=

# Show the AI's action plan before executing?  true | false  (default: true)
# AI_PLAN_PREVIEW=true

# Enable AI self-reflection after each action?  true | false  (default: false)
# AI_REFLECTION=false

# Enable the guild observer (AI watches events and acts proactively)?  (default: true)
# AI_OBSERVER=true

# ── SUPPORT INBOX (optional) ─────────────────────────────────────────────────

# Role ID whose members can see/reply to support conversations
# SUPPORT_STAFF_ROLE_ID=

# Override which channel to use as the Discord-native Support Inbox dashboard
# (leave blank and the bot auto-creates #📥-support-inbox)
# CHANNEL_SUPPORT_INBOX=

# ── VOICE AI (optional) ───────────────────────────────────────────────────────

# STT provider: whisper | deepgram | assemblyai | google  (default: whisper)
# STT_PROVIDER=whisper

# TTS provider: openai | elevenlabs | azure | google  (default: openai)
# TTS_PROVIDER=openai

# Voice personality: friendly | professional | gaming | funny | assistant  (default: assistant)
# VOICE_PERSONALITY=assistant

# ElevenLabs API key (only if TTS_PROVIDER=elevenlabs)
# ELEVENLABS_API_KEY=

# ── MISC (optional) ───────────────────────────────────────────────────────────

# How often (ms) to refresh the status embed. Minimum 3000.  (default: 3000)
# UPDATE_INTERVAL_MS=3000
